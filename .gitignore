*.dmg
*.zip
*.app

# Logs
*.log
npm-debug.log*

# Secrets & per-user config — NEVER commit (see ADR-002)
.env
.env.*
!.env.example
*.pem
*.p12
*.mobileprovision
secrets.json
*.secret

# macOS
.DS_Store

# Editor / tooling
.vscode/
.idea/

