# agents-orchestrator — example environment.
# Copy to `.env` (gitignored) for LOCAL DEV ONLY. The app reads NO secrets at
# runtime and stores none — it's a read-only viewer (ADR-001). MCP secrets live
# in ~/.claude.json, managed by Claude Code, not by this app (ADR-008).
#
# These are only used by maintainer tooling (e.g. signing/notarization in CI).

# macOS code-signing / notarization (release builds only — never commit real values)
# APPLE_ID=
# APPLE_APP_SPECIFIC_PASSWORD=
# APPLE_TEAM_ID=
# CSC_LINK=               # path to .p12 or base64 cert
# CSC_KEY_PASSWORD=
