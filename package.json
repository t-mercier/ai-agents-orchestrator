{
  "name": "ai-agents-orchestrator",
  "version": "0.1.0",
  "description": "Live mission control for all your parallel Claude Code sessions — a native macOS dashboard.",
  "license": "SEE LICENSE IN LICENSE",
  "homepage": "https://github.com/t-mercier/ai-agents-orchestrator",
  "repository": {
    "type": "git",
    "url": "https://github.com/t-mercier/ai-agents-orchestrator.git"
  },
  "scripts": {
    "install:skills": "bash scripts/install.sh",
    "build:xterm": "esbuild build/xterm-entry.js --bundle --format=iife --global-name=XtermBundle --outfile=renderer/xterm-bundle.js",
    "test": "jest",
    "check:secrets": "bash scripts/check-no-secrets.sh"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "jest": "^29.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.js"
    ]
  },
  "dependencies": {
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-web-links": "^0.12.0",
    "xterm": "^5.3.0",
    "xterm-addon-canvas": "^0.5.0",
    "xterm-addon-webgl": "^0.16.0"
  }
}
